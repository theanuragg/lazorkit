// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                             String    @id @default(cuid())
  email                          String    @unique
  displayName                    String
  solanaAddress                  String?    @unique
  
  // Passkey authentication
  passkeyChallenge               String?
  passkeyChallengeExpiresAt      DateTime?
  
  // Balance caching
  cachedBalance                  Float     @default(0)
  balanceUpdatedAt               DateTime  @default(now())
  
  // Metadata
  lastLoginAt                    DateTime?
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt
  
  // Relations
  transactions                   Transaction[]
  
  @@index([email])
  @@index([solanaAddress])
}

model Transaction {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields:  [userId], references: [id], onDelete: Cascade)
  
  recipientAddress    String
  amountSol           Float
  
  // Transaction metadata
  solanaSignature     String?   @unique
  status              String    @default("PENDING_SIGNATURE") // PENDING_SIGNATURE, SIGNED, CONFIRMED, FAILED
  errorMessage        String?
  
  createdAt           DateTime  @default(now())
  confirmedAt         DateTime?
  
  @@index([userId])
  @@index([status])
  @@index([solanaSignature])
}